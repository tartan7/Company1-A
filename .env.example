# Outbound email service configuration
# Copy to .env and fill in values before running in non-dev environments.
# Reference: ESC-828

# Set to "true" to enable actual email sending.
# Leave unset or "false" in development — all sends will be logged but skipped.
EMAIL_ENABLED=false

# Email provider: "resend" (default) or "ses"
EMAIL_PROVIDER=resend

# Verified sender identity — must be verified with your email provider.
EMAIL_FROM=outreach@unitecube.jp

# Resend API key (required when EMAIL_PROVIDER=resend)
# Obtain from https://resend.com/api-keys
RESEND_API_KEY=

# AWS SES credentials (required when EMAIL_PROVIDER=ses)
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
